# ======================================================
#  SIPMA - Environment Variables
#  Salin file ini menjadi .env lalu isi nilainya
# ======================================================

# Supabase Database Configuration
# Dapatkan connection string dari: https://supabase.com/dashboard/project/<ref>/settings/database
# Pilih bagian "Connection pooling" > Session mode (port 5432)
DB_URL=jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_DATABASE_PASSWORD

# Gmail SMTP Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

